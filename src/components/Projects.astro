---
// Add entries like:
// { title: 'Name', description: 'One real sentence about what it does and why.',
//   tech: 'TypeScript · Astro', github: 'https://github.com/nickleigh05/repo',
//   live: '', status: 'in progress' }
interface Project {
  title: string
  description: string
  tech: string
  github?: string
  live?: string
  status?: string
}

const projects: Project[] = [
  {
    title: 'NNFS',
    description:
      'A neural network built from scratch in plain Python. Layers, activations, and backpropagation with no frameworks, so every moving part is understood.',
    tech: 'python',
    github: 'https://github.com/nickleigh05/NNFS',
  },
  {
    title: 'nicksnexus',
    description:
      'My personal portfolio website, dark glass floating over a live WebGL backdrop. But you’re already here!',
    tech: 'typescript · astro · three.js',
    github: 'https://github.com/nickleigh05/nicksnexus',
  },
  {
    title: 'LeetCode',
    description:
      'My DSA grind, tracked in the open. Solutions organized by topic and difficulty across Blind 75, NeetCode 150, and NeetCode 250.',
    tech: 'python',
    github: 'https://github.com/nickleigh05/LeetCode',
  },
  {
    title: 'MMA-Machine',
    description:
      'A mathematical MMA evolution engine where MuJoCo humanoid fighters learn to fight through PPO and league self-play.',
    tech: 'python · mujoco · rl',
    github: 'https://github.com/nickleigh05/MMA-Machine',
    status: 'in progress',
  },
]
---

{
  projects.length > 0 && (
    <section id="projects" class="scroll-mt-28 pb-36" data-reveal-group>
      <p class="mb-3 font-mono text-xs tracking-[0.2em] text-accent uppercase" data-reveal>
        10 / projects
      </p>
      <h2 class="mb-10 font-display text-4xl font-bold tracking-tight sm:text-5xl" data-reveal>
        Things I've built.
      </h2>
      <ul class="grid gap-6 sm:grid-cols-2">
        {projects.map(({ title, description, tech, github, live, status }) => {
          const href = live || github
          const inner = (
            <>
              <h3 class="font-display text-2xl font-bold tracking-tight transition-colors duration-(--dur-micro) group-hover:text-accent">
                {title}
                {href && (
                  <span
                    class="ml-2 inline-block text-accent opacity-0 transition-all duration-(--dur-ui) ease-(--ease-out-expo) group-hover:translate-x-1 group-hover:opacity-100"
                    aria-hidden="true"
                  >
                    →
                  </span>
                )}
              </h3>
              {status && (
                <span class="mt-3 inline-block rounded-full border border-accent/40 px-2.5 py-0.5 font-mono text-[10px] tracking-[0.18em] text-accent-glow uppercase">
                  {status}
                </span>
              )}
              <p class="mt-3 leading-relaxed text-ink-soft">{description}</p>
              <p class="mt-6 font-mono text-xs text-accent/80">{tech}</p>
            </>
          )
          const cardClass =
            'glass-bright group pointer-events-auto block h-full rounded-3xl p-8 transition-[border-color,box-shadow,background-color] duration-(--dur-ui) ease-(--ease-out-expo) hover:border-white/35 hover:bg-white/10 hover:shadow-[0_0_48px_rgb(124_58_237/0.3)]'
          return (
            <li data-reveal data-tilt class="will-change-transform">
              {href ? (
                <a href={href} target="_blank" rel="noopener" class={cardClass}>
                  {inner}
                </a>
              ) : (
                <div class={cardClass}>{inner}</div>
              )}
            </li>
          )
        })}
      </ul>
    </section>
  )
}

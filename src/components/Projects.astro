          </div>

          <h4 class="text-white font-semibold text-lg mb-2">{title}</h4>
          <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-4">{description}</p>

          <ul class="flex flex-wrap gap-2">
            {tech.map(t => (
              <li class="text-indigo-400 font-mono text-xs">{t}</li>

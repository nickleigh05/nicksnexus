---
// Add entries like:
// { title: 'Name', description: 'One real sentence about what it does and why.',
//   tech: 'TypeScript · Astro', github: 'https://github.com/nickleigh05/repo',
//   live: '', status: 'in progress' }
interface Project {
  title: string
  description: string
  tech: string
  github?: string
  live?: string
  status?: string
}

const projects: Project[] = [
  {
    title: 'NNFS',
    description:
      'A neural network built from scratch in plain Python — layers, activations, backpropagation — no frameworks, so every moving part is understood.',
    tech: 'python',
    github: 'https://github.com/nickleigh05/NNFS',
  },
  {
    title: 'Next build',
    description:
      'Something bigger at the intersection of cloud and AI/ML. In progress now — on GitHub when it’s ready.',
    tech: 'cloud · ai/ml',
    status: 'in progress',
  },
]
---

{
  projects.length > 0 && (
    <section id="work" class="pb-28" data-reveal-group>
      <h2 class="mb-10 font-mono text-xs tracking-[0.2em] text-neon-blue uppercase" data-reveal>
        10 / selected work
      </h2>
      <ul class="grid gap-6 sm:grid-cols-2">
        {projects.map(({ title, description, tech, github, live, status }) => {
          const href = live || github
          const inner = (
            <>
              <h3 class="font-display text-2xl font-bold tracking-tight transition-colors duration-(--dur-micro) group-hover:text-neon-blue">
                {title}
                {href && (
                  <span
                    class="ml-2 inline-block text-neon-blue opacity-0 transition-all duration-(--dur-ui) ease-(--ease-out-expo) group-hover:translate-x-1 group-hover:opacity-100"
                    aria-hidden="true"
                  >
                    →
                  </span>
                )}
              </h3>
              {status && (
                <span class="mt-3 inline-block rounded-full border border-neon-pink/40 px-2.5 py-0.5 font-mono text-[10px] tracking-[0.18em] text-neon-pink uppercase">
                  {status}
                </span>
              )}
              <p class="mt-3 leading-relaxed text-ink-soft">{description}</p>
              <p class="mt-6 font-mono text-xs text-neon-blue/80">{tech}</p>
            </>
          )
          const cardClass =
            'glass-bright group pointer-events-auto block h-full rounded-3xl p-8 transition-[border-color,box-shadow] duration-(--dur-ui) ease-(--ease-out-expo) hover:border-white/35 hover:shadow-[0_0_48px_rgb(139_92_246/0.3)]'
          return (
            <li data-reveal data-tilt class="will-change-transform">
              {href ? (
                <a href={href} target="_blank" rel="noopener" class={cardClass}>
                  {inner}
                </a>
              ) : (
                <div class={cardClass}>{inner}</div>
              )}
            </li>
          )
        })}
      </ul>
    </section>
  )
}

<section id="projects" class="py-24 border-t border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-sm font-mono text-indigo-400 mb-2">03. projects</h2>
    <h3 class="text-3xl font-bold text-white mb-12">Things I've built</h3>


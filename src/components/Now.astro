---
// the "currently" pulse; short, present tense, easy to update as things change
const items = [
  'Studying for the AWS Cloud Practitioner certification.',
  'Building MMA-Machine, a reinforcement learning fight engine.',
  'Grinding through the NeetCode 150 in my LeetCode repository.',
]
---

<section id="now" class="scroll-mt-28 pb-36" data-reveal-group>
  <p class="mb-3 font-mono text-xs tracking-[0.2em] text-neon-orange uppercase" data-reveal>
    100 / currently
  </p>
  <h2 class="mb-10 font-display text-4xl font-bold tracking-tight sm:text-5xl" data-reveal>
    What I'm up to.
  </h2>
  <ul class="max-w-2xl space-y-5">
    {
      items.map((item, i) => (
        <li class="flex items-baseline gap-4" data-reveal>
          <span class="font-mono text-xs text-neon-orange">{String(i + 1).padStart(2, '0')}</span>
          <p class="text-lg leading-relaxed text-ink-soft">{item}</p>
        </li>
      ))
    }
  </ul>
</section>

---
// one card per channel so people land exactly where they're headed
interface Social {
  label: string
  value: string
  blurb: string
  href: string
  id?: string
  external?: boolean
}

const socials: Social[] = [
  {
    label: 'email',
    value: 'nickleigh05@icloud.com',
    blurb: 'The fastest way to reach me. My inbox is always open.',
    href: 'mailto:nickleigh05@icloud.com',
    id: 'email',
  },
  {
    label: 'linkedin',
    value: 'nicholas leigh',
    blurb: 'The professional rundown. Let’s connect.',
    href: 'https://www.linkedin.com/in/-nicholas-leigh',
    external: true,
  },
  {
    label: 'github',
    value: '@nickleigh05',
    blurb: 'Where all the code actually lives.',
    href: 'https://github.com/nickleigh05',
    external: true,
  },
]

// email addresses are one long token; offer a soft break before the @ so
// narrow cards wrap there instead of mid-word ("@nickleigh05" stays whole)
const valueParts = (v: string) => {
  const at = v.indexOf('@', 1)
  return at === -1 ? [v] : [v.slice(0, at), v.slice(at)]
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<section id="socials" class="scroll-mt-28 pb-28" data-reveal-group>
  <p class="mb-3 font-mono text-xs tracking-[0.2em] text-accent uppercase" data-reveal>
    101 / contact &amp; socials
  </p>
  <h2 class="mb-10 font-display text-4xl font-bold tracking-tight sm:text-5xl" data-reveal>
    Get in touch.
  </h2>
  <div class="glass-bright rounded-3xl px-8 py-12 text-center sm:px-16" data-reveal>
    <p class="font-display text-3xl font-bold tracking-tight sm:text-5xl">
      Looking for a <span class="text-neon">2027 swe internship</span>
    </p>
    <p class="mx-auto mt-5 max-w-md leading-relaxed text-ink-soft">
      If you're hiring, or you just want to talk shop, pick whichever door you like.
    </p>
    <div class="pointer-events-auto mt-8">
      <a href={`${base}/resume.pdf`} target="_blank" class="btn-glass" data-magnetic>
        view my resume
      </a>
    </div>
  </div>
  <ul class="mt-6 grid gap-6 sm:grid-cols-3">
    {
      socials.map(({ label, value, blurb, href, id, external }) => (
        <li id={id} data-reveal data-tilt class="scroll-mt-28 will-change-transform">
          <a
            href={href}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener' : undefined}
            class="group glass-bright pointer-events-auto block h-full rounded-3xl p-9 transition-[border-color,box-shadow,background-color] duration-(--dur-ui) ease-(--ease-out-expo) hover:border-white/35 hover:bg-white/10 hover:shadow-[0_0_48px_rgb(124_58_237/0.3)]"
          >
            <p class="font-mono text-xs tracking-[0.18em] text-accent uppercase">{label}</p>
            <p class="mt-4 font-display text-xl font-bold tracking-tight break-words transition-colors duration-(--dur-micro) group-hover:text-accent">
              {valueParts(value).map((part, i) => (
                <>
                  {i > 0 && <wbr />}
                  {part}
                </>
              ))}
              <span
                class="ml-2 inline-block text-accent opacity-0 transition-all duration-(--dur-ui) ease-(--ease-out-expo) group-hover:translate-x-1 group-hover:opacity-100"
                aria-hidden="true"
              >
                →
              </span>
            </p>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{blurb}</p>
          </a>
        </li>
      ))
    }
  </ul>
</section>

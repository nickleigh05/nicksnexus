---
const skills = [
  { category: 'Languages', items: ['JavaScript', 'TypeScript', 'Python', 'HTML', 'CSS'] },
  { category: 'Frameworks', items: ['React', 'Node.js', 'Astro'] },
  { category: 'Tools', items: ['Git', 'GitHub', 'VS Code', 'Figma'] },
]
---

<section id="skills" class="py-24 border-t border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-sm font-mono text-indigo-400 mb-2">02. skills</h2>
    <h3 class="text-3xl font-bold text-white mb-12">What I work with</h3>

    <div class="grid sm:grid-cols-3 gap-6">
      {skills.map(({ category, items }) => (
        <div class="bg-gray-900 rounded-lg p-6 border border-gray-800">
          <h4 class="text-indigo-400 font-mono text-sm mb-4">{category}</h4>
          <ul class="space-y-2">
            {items.map(item => (
              <li class="text-gray-300 flex items-center gap-2">
                <span class="text-indigo-500 text-xs">▹</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

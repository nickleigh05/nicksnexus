---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'Nicholas Leigh' } = Astro.props
const description =
  'Nicholas Leigh is a computer science student at Arizona State University working on data structures and algorithms, AI/ML models, and AWS cloud.'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const year = new Date().getFullYear()
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080302" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <noscript>
      <style>
        [data-reveal],
        [data-hero] {
          opacity: 1 !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-void font-sans text-ink antialiased">
    <!-- layer 1: live WebGL background, fixed behind everything -->
    <canvas id="webgl-bg" class="fixed top-0 left-0 z-0 h-screen w-screen" aria-hidden="true"
    ></canvas>
    <div class="grain" aria-hidden="true"></div>

    <!-- layer 2: UI overlay — inert by default so the canvas shows through;
         interactive elements opt back in with pointer-events-auto -->
    <div class="pointer-events-none relative z-10">
      <header class="fixed inset-x-0 top-0 z-20 px-4" data-hero="frame">
        <nav
          class="glass pointer-events-auto mx-auto mt-4 flex max-w-5xl items-center justify-between rounded-full px-6 py-3"
        >
          <a
            href={`${base}/`}
            class="font-display text-lg font-bold tracking-tight transition-colors duration-(--dur-micro) hover:text-neon-orange"
          >
            nicholas leigh<span class="text-neon">.</span>
          </a>
          <!-- every link jumps straight to its destination; on small screens
               only projects + socials fit, and socials covers the rest -->
          <div class="flex items-center gap-4 text-sm sm:gap-6">
            <a href="#projects" class="link-ink">projects</a>
            <a href="#email" class="hidden link-ink sm:inline">email</a>
            <a
              href="https://www.linkedin.com/in/-nicholas-leigh"
              target="_blank"
              rel="noopener"
              class="hidden link-ink sm:inline"
            >
              linkedin
            </a>
            <a
              href="https://github.com/nickleigh05"
              target="_blank"
              rel="noopener"
              class="hidden link-ink sm:inline"
            >
              github
            </a>
            <a href="#socials" class="link-ink">socials</a>
            <a href={`${base}/resume.pdf`} target="_blank" class="hidden link-ink sm:inline">
              resume
            </a>
          </div>
        </nav>
      </header>

      <main class="mx-auto max-w-5xl px-6">
        <slot />
      </main>

      <footer class="mx-auto max-w-5xl px-6 pb-12">
        <div
          class="flex flex-col gap-6 border-t border-hairline pt-10 sm:flex-row sm:items-end sm:justify-between"
        >
          <div>
            <p class="font-display text-lg font-bold tracking-tight">
              nicholas leigh<span class="text-neon">.</span>
            </p>
            <p class="mt-1 text-sm text-ink-soft">
              cs student building things in the arizona valley.
            </p>
          </div>
          <div class="pointer-events-auto flex flex-wrap items-center gap-5 text-sm">
            <a href="mailto:nickleigh05@icloud.com" class="link-ink">email</a>
            <a
              href="https://www.linkedin.com/in/-nicholas-leigh"
              target="_blank"
              rel="noopener"
              class="link-ink"
            >
              linkedin
            </a>
            <a
              href="https://github.com/nickleigh05"
              target="_blank"
              rel="noopener"
              class="link-ink"
            >
              github
            </a>
            <a href={`${base}/resume.pdf`} target="_blank" class="link-ink">resume</a>
          </div>
        </div>
        <div
          class="mt-8 flex flex-wrap items-baseline justify-between gap-2 font-mono text-xs text-ink-soft"
        >
          <span>designed &amp; built by nicholas leigh · astro + three.js</span>
          <span
            >© {year} · <span title={`${year} in hexadecimal`}
              >0x{year.toString(16).toUpperCase()}</span
            ></span
          >
        </div>
      </footer>
    </div>

    <script>
      import { initWebGLBackground } from '../scripts/webgl-bg'
      import '../scripts/motion'

      // boot WebGL after load so LCP locks onto the headline, not the canvas;
      // until then the CSS aurora wash holds the frame
      const boot = () => {
        const canvas = document.getElementById('webgl-bg')
        if (canvas instanceof HTMLCanvasElement) initWebGLBackground(canvas)
      }
      if (document.readyState === 'complete') boot()
      else window.addEventListener('load', boot, { once: true })
    </script>
  </body>
</html>
